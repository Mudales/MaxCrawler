# Copy this file to .env and fill in your MAX credentials

# Your MAX login credentials
MAX_USERNAME=your_email@example.com
MAX_PASSWORD=your_password

# API version string — update if MAX changes it (visible in DevTools → cav header)
MAX_CAV=V4.209-RC.14.88

# Your browser's User-Agent (optional — default works fine)
# MAX_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Path to SQLite database file (optional)
DB_PATH=transactions.db
